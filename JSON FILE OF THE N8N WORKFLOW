photos') return 'photos';\n  if (r.indexOf('sidecar') >= 0 || r.indexOf('carousel') >= 0) return 'carousel';\n  return r;\n}\n\nconst userRoute = mapToUserRoute(computedRoute, postData);\n\n/******* 6) Merge and return *******/\nconst merged = { ...(postData || {}), processedCaption };\n\nconst rootKeys = Object.keys(merged || {});\nconst allKeys = collectAllKeys(merged || {});\nconst modelOutputKeys = (modelItem && typeof modelItem === 'object') ? Object.keys(modelItem) : [];\n\nreturn [\n  {\n    json: {\n      ...merged,\n      route: computedRoute,\n      userRoute,\n      _debug: {\n        // show a compact preview so you can validate quickly\n        rootKeys,\n        allKeys,\n        modelOutputKeys,\n        // preview of model output and Normalize node read attempt\n        normalizedNodeSeen: !!(postData && Object.keys(postData).length),\n        rawModelOutputPreview: typeof rawModelOutput === 'string' ? rawModelOutput.slice(0,2000) : JSON.stringify(rawModelOutput || {}).slice(0,2000),\n      },\n    },\n  },\n];"
