erns so we don't miss the Normalize node output\ntry {\n  if (typeof $node !== 'undefined' && $node[\"Normalize Post Data\"]) {\n    const np = $node[\"Normalize Post Data\"];\n\n    // Common: Code node returns .item.json\n    if (np.item && np.item.json) {\n      postData = np.item.json;\n    }\n    // Common: Code node exposes .json\n    else if (np.json) {\n      postData = np.json;\n    }\n    // Some runtimes expose an array of items\n    else if (Array.isArray(np) && np.length && np[0].json) {\n      postData = np[0].json;\n    }\n    // Another possibility: node object contains nodes keyed by index\n    else if (np[0] && np[0].json) {\n      postData = np[0].json;\n    }\n  }\n\n  // If still empty, try incoming items (maybe Normalize output was passed in as the incoming item)\n  if ((!postData || Object.keys(postData).length === 0) && Array.isArray(items) && items.length) {\n    // pick the first incoming item that looks like a post (has timestamp or type/postType/videoUrl)\n    for (const it of items) {\n      if (it && it.json && (it.json.postType || it.json.type || it.json.timestamp || it.json.videoUrl || it.json.images)) {\n        postData = it.json;\n        break;\n      }\n    }\n  }\n} catch (err) {\n  // keep postData = {}\n}\n\n/******* 2) Read model output (message a model) *******/\nconst modelItem = (Array.isArray(items) && items[0] && items[0].json) ? items[0].json : null;\nconst rawModelOutput = modelItem;\n\n/******* 3) Extract processed caption (prefer model output) *******/\nlet processedCaption = (postData && (postData.captionRaw || postData.caption)) ? (postData.captionRaw || postData.caption).toString() : '';\n\ntry {\n  const extracted = extractTextFromModel(modelItem);\n  if (extracted && extracted.toString().trim().length > 0) processedCaption = extracted.toString().trim();\n} catch (e) { /* ignore and keep captionRaw */ }\n\n/******* 4) Reliable route computation *******/\nfunction valueToLower(v){ return (v || '').toString().toLow